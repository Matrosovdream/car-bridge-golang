# Copy to .env for local development (auto-loaded on startup).

# Postgres connection string (overrides database.url in config.yaml)
DATABASE_URL=postgres://carbridge:carbridge@localhost:5432/carbridge?sslmode=disable

# Redis (overrides redis.url; rate-limiter storage). Leave empty for in-memory.
REDIS_URL=redis://localhost:6379/0

# --- integration secrets ---
# FMCSA QCMobile / SAFER webKey
SAFERWEB_WEBKEY=

# Plaid
PLAID_CLIENT_ID=
PLAID_SECRET=
